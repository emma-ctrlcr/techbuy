# ── Base de datos ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=tu_password
DB_NAME=tbuy_db

# ── Servidor ──────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────
FRONTEND_URL=*

# ── Uploads del módulo admin ──────────────────────────────────
# Ruta ABSOLUTA a la carpeta uploads/ del módulo admin.
# El backend la sirve en /uploads para que el frontend pueda cargar las imágenes.
# Ejemplo Windows: C:\proyectos\modulo admin 5.0\uploads
# Ejemplo Linux/Mac: /home/usuario/modulo admin 5.0/uploads
ADMIN_UPLOADS_DIR=../modulo admin 5.0/uploads

# ── JWT (si lo usas) ──────────────────────────────────────────
JWT_SECRET=tu_jwt_secret_aqui
