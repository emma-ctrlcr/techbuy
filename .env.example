# ═══════════════════════════════════════════════════════════════
# TECHBUY — Variables de Entorno
# Copia este archivo como .env y completa los valores
# ═══════════════════════════════════════════════════════════════

# ── Servidor ──────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── PostgreSQL ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tbuy_db
DB_USER=postgres
DB_PASSWORD=tu_password_segura

# ── JWT (tokens de autenticación) ──────────────────────────────
# Usa `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
# para generar valores en producción
JWT_ACCESS_SECRET=genera_un_secreto_aleatorio_aqui
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=genera_otro_secreto_aleatorio_aqui
JWT_REFRESH_EXPIRES_IN=30d

# ── CSRF ───────────────────────────────────────────────────────
CSRF_SECRET=genera_un_secreto_csrf_aqui

# ── CORS ──────────────────────────────────────────────────────
# URL exacta del frontend (sin barra al final)
FRONTEND_URL=http://localhost:4000

# ── Uploads (opcional) ────────────────────────────────────────
# ADMIN_UPLOADS_DIR=../modulo admin 5.0/uploads
